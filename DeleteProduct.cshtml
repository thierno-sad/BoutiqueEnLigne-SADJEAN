@model BoutiqueEnLigne.Models.Product
@{
    ViewData["Title"] = "Supprimer produit";
}

<div class="sj-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="sj-hero mb-3">
                    <div class="sj-kicker">SADJEAN • Seller</div>
                    <h1 class="sj-title mt-2" style="color:#ff6b6b;">Supprimer le produit</h1>
                    <p class="sj-subtitle mt-1">Confirmation : cette action est irréversible.</p>
                </div>

                <div class="sj-card p-4 p-md-5">
                    <div class="sj-text fw-bold">@Model.Title</div>
                    <div class="sj-muted">@Model.Category</div>
                    <div class="mt-2" style="color: var(--sj-gold); font-weight: 900; font-size: 1.4rem;">
                        @Model.Price.ToString("0.00") $
                    </div>

                    <hr style="border-color: rgba(255,255,255,.12);" />

                    <form asp-action="ConfirmDelete" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="d-grid gap-2">
                            <button class="btn sj-btn btn-danger btn-lg fw-bold">Oui, supprimer</button>
                            <a class="btn sj-btn sj-btn-outline-gold"
                               asp-controller="Seller" asp-action="Dashboard">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>