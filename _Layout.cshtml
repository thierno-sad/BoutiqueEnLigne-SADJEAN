@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BoutiqueEnLigne</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BoutiqueEnLigne.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning" href="/">
                    🔥 SADJEAN
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Produits</a>
                        </li>

                        @{
                            var userId = Context.Session.GetInt32("UserId");
                            var userName = Context.Session.GetString("UserName");
                            var userRole = Context.Session.GetString("UserRole");
                        }

                        @if (userId == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/User/Register">Inscription</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning fw-bold rounded-3 px-3" href="/User/Login">Connexion</a>
                            </li>
                        }
                        else
                        {
                            @if (userRole == "Client")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Cart">Panier</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Order/MyOrders">Mes achats</a>
                                </li>
                            }
                            

                            @if (userRole == "Vendeur")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Seller/MySales">Mes ventes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Seller/Dashboard">Espace Vendeur</a>
                                </li>
                            }

                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    Bonjour <span class="text-warning fw-bold">@userName</span>
                                    <span class="text-muted">(@userRole)</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/User/Profile">Profil</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-warning rounded-3 px-3" href="/User/Logout">Logout</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BoutiqueEnLigne - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
