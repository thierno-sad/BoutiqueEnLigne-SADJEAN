@{
    ViewData["Title"] = "Accueil";
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
}

<div class="sj-page">
    <div class="container py-5">

        <div class="sj-hero mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">

                    <h1 class="sj-title mt-2">
                        Bienvenue sur <span style="color: var(--sj-gold);">SADJEAN</span>
                    </h1>

                    <p class="sj-subtitle mt-2">
                        Découvre des produits stylés, achète en confiance et profite d’une expérience premium.
                    </p>

                    @if (userId != null)
                    {
                        <div class="mt-3 sj-text">
                            Connecté en tant que <span style="color: var(--sj-gold); font-weight:900;">@userName</span>
                            <span class="sj-muted">(@userRole)</span>
                        </div>
                    }

                    <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                        <a class="btn sj-btn sj-btn-gold px-4 py-2"
                           asp-controller="Home"
                           asp-action="Start">
                            Commencer maintenant
                        </a>

                        <a class="btn sj-btn sj-btn-outline-gold px-4 py-2"
                           asp-controller="Product"
                           asp-action="Index">
                            Voir le catalogue
                        </a>

                        @if (userRole == "Vendeur")
                        {
                            <a class="btn sj-btn btn-outline-light px-4 py-2"
                               asp-controller="Seller"
                               asp-action="Dashboard">
                                Espace vendeur
                            </a>
                        }
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-4">
                        <span class="sj-badge">Paiement sécurisé</span>
                        <span class="sj-badge">Produits premium</span>
                        <span class="sj-badge">Expérience rapide</span>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="sj-card sj-card-hover p-4">
                        <div class="sj-text fw-bold mb-1">✨ Pourquoi SADJEAN ?</div>
                        <div class="sj-muted">
                            • Catalogue clair et moderne<br />
                            • Recherche + filtres rapides<br />
                            • Espace vendeur pour publier des articles<br />
                            • Paiement Stripe
                        </div>

                        <hr style="border-color: rgba(255,255,255,.12);" />

                        <div class="row g-3">
                            <div class="col-6">
                                <div class="sj-card p-3">
                                    <div class="sj-muted small">Produits</div>
                                    <div class="sj-text fw-bold fs-4">@ViewBag.ProductCount</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="sj-card p-3">
                                    <div class="sj-muted small">Catégories</div>
                                    <div class="sj-text fw-bold fs-4">@ViewBag.CategoryCount</div>
                                </div>
                            </div>
                        </div>

                        <p class="sj-muted small mt-3 mb-0">
                            Astuce : connecte-toi pour accéder au catalogue et gérer ton profil.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="sj-card sj-card-hover p-4 h-100">
                    <div class="sj-text fw-bold">🛍️ Catalogue</div>
                    <p class="sj-muted mb-0">Une liste propre, avec détails, tri et filtres.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="sj-card sj-card-hover p-4 h-100">
                    <div class="sj-text fw-bold">👤 Compte</div>
                    <p class="sj-muted mb-0">Inscription, connexion, sessions, profil.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="sj-card sj-card-hover p-4 h-100">
                    <div class="sj-text fw-bold">💳 Paiement</div>
                    <p class="sj-muted mb-0">Stripe checkout + facture.</p>
                </div>
            </div>
        </div>

    </div>
</div>
