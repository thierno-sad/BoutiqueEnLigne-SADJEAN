@model BoutiqueEnLigne.Models.Order
@{
    ViewData["Title"] = "Facture";

    var bySeller = Model.Items
        .GroupBy(i => i.Seller?.Fullname ?? ("Vendeur #" + i.SellerId))
        .Select(g => new { Seller = g.Key, Total = g.Sum(x => x.LineTotal) })
        .OrderByDescending(x => x.Total)
        .ToList();
}

<div class="sj-page">
    <div class="container py-4">

        <div class="sj-hero mb-4">
            <h1 class="sj-title">Facture #@Model.Id</h1>

            <p class="sj-subtitle">
                Date :
                <span class="sj-text fw-bold">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                • Statut : <span class="sj-badge">@Model.PaymentStatus</span>
                • Total :
                <strong style="color:var(--sj-gold)">@Model.TotalAmount.ToString("0.00") $</strong>
            </p>

            <p class="sj-muted small mb-0">
                PaymentIntent : @Model.StripePaymentIntentId
            </p>
        </div>

        <div class="row g-3 g-lg-4">

            
            <div class="col-12 col-lg-8">
                <div class="sj-card p-3 p-md-4">
                    <div class="table-responsive">
                        <table class="table table-dark table-borderless align-middle mb-0">
                            <thead>
                                <tr class="sj-muted">
                                    <th>Produit</th>
                                    <th>Vendeur</th>
                                    <th class="text-end">Prix</th>
                                    <th class="text-end">Qté</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var it in Model.Items)
                                {
                                    <tr>
                                        <td class="sj-text fw-bold">@it.Product?.Title</td>
                                        <td class="sj-muted">
                                            @(it.Seller != null ? it.Seller.Fullname : "Vendeur inconnu")
                                        </td>
                                        <td class="text-end sj-muted">@it.UnitPrice.ToString("0.00") $</td>
                                        <td class="text-end sj-muted">@it.Quantity</td>
                                        <td class="text-end" style="color:var(--sj-gold);font-weight:800;">
                                            @it.LineTotal.ToString("0.00") $
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a class="btn sj-btn sj-btn-outline-gold" href="/Order/MyOrders">Retour historique</a>
                        <div class="sj-text fw-bold">
                            Total :
                            <span style="color:var(--sj-gold)">@Model.TotalAmount.ToString("0.00") $</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="sj-card p-3 p-md-4" style="position: sticky; top: 90px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-bold sj-text">Répartition vendeurs</div>
                        <span class="sj-badge">SADJEAN</span>
                    </div>
                    <p class="sj-muted mb-3">Montants par vendeur</p>

                    @foreach (var s in bySeller)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="sj-muted">@s.Seller</span>
                            <span class="sj-text fw-bold" style="color:var(--sj-gold)">
                                @s.Total.ToString("0.00") $
                            </span>
                        </div>
                    }

                    <hr class="text-white-50 my-3" />

                    <div class="d-flex justify-content-between">
                        <span class="sj-muted">Total facture</span>
                        <span class="sj-text fw-bold" style="color:var(--sj-gold)">
                            @Model.TotalAmount.ToString("0.00") $
                        </span>
                    </div>

                    <div class="mt-3">
                        <a class="btn sj-btn sj-btn-gold w-100" href="/Product">Continuer shopping</a>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>