@model List<BoutiqueEnLigne.Models.Product>
@{
    ViewData["Title"] = "Espace Vendeur";

    var count = Model?.Count ?? 0;
    var totalValue = Model?.Sum(p => p.Price) ?? 0m;
    var categoryCount = Model?.Select(p => p.Category).Distinct().Count() ?? 0;
}

<div class="sj-page py-4">
    <div class="container">

        <div class="sj-hero mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
                <div>
                  
                    <h1 class="sj-title mt-2">Espace Vendeur</h1>
                    <p class="sj-subtitle mt-1">Publie et gère tes articles en mode premium.</p>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn sj-btn sj-btn-outline-gold px-4"
                       asp-controller="Product" asp-action="Index">
                        Voir catalogue
                    </a>
                    <a class="btn sj-btn sj-btn-gold px-4"
                       asp-controller="Seller" asp-action="AddProduct">
                        + Ajouter un produit
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="sj-card sj-card-hover p-4 h-100">
                    <div class="sj-muted">Produits publiés</div>
                    <div class="sj-text fw-bold" style="font-size:2rem;">@count</div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="sj-card sj-card-hover p-4 h-100">
                    <div class="sj-muted">Catégories</div>
                    <div class="sj-text fw-bold" style="font-size:2rem;">@categoryCount</div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="sj-card sj-card-hover p-4 h-100">
                    <div class="sj-muted">Valeur totale (prix)</div>
                    <div style="color: var(--sj-gold); font-weight:900; font-size:2rem;">
                        @totalValue.ToString("0.00") $
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="sj-text fw-bold m-0">Mes produits</h2>
            <a class="btn sj-btn sj-btn-outline-gold"
               asp-controller="User" asp-action="Profile">
                Mon profil
            </a>
        </div>

        @if (count == 0)
        {
            <div class="sj-card p-4">
                <div class="sj-text fw-bold">Aucun produit</div>
                <p class="sj-muted mb-3">Ajoute ton premier article pour commencer à vendre.</p>
                <a class="btn sj-btn sj-btn-gold"
                   asp-controller="Seller" asp-action="AddProduct">
                    Publier maintenant
                </a>
            </div>
        }
        else
        {
            <div class="sj-card overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width:90px;">Image</th>
                                <th>Produit</th>
                                <th>Catégorie</th>
                                <th class="text-end">Prix</th>
                                <th class="text-end" style="width:260px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td>
                                        <div style="width:70px;height:52px;border-radius:12px;overflow:hidden;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.10);">
                                            <img src="@(string.IsNullOrWhiteSpace(p.ImageUrl) ? "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab" : p.ImageUrl)"
                                                 style="width:100%;height:100%;object-fit:cover;display:block;" />
                                        </div>
                                    </td>

                                    <td>
                                        <div class="sj-text fw-bold">@p.Title</div>
                                        <div class="sj-muted small">ID: #@p.Id</div>
                                    </td>

                                    <td><span class="sj-badge">@p.Category</span></td>

                                    <td class="text-end">
                                        <span style="color: var(--sj-gold); font-weight:900;">
                                            @p.Price.ToString("0.00") $
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <a class="btn btn-sm sj-btn sj-btn-outline-gold"
                                               asp-controller="Product" asp-action="Details" asp-route-id="@p.Id">
                                                Détails
                                            </a>
                                            <a class="btn btn-sm btn-outline-light sj-btn"
                                               asp-controller="Seller" asp-action="EditProduct" asp-route-id="@p.Id">
                                                Modifier
                                            </a>
                                            <a class="btn btn-sm btn-outline-danger sj-btn"
                                               asp-controller="Seller" asp-action="DeleteProduct" asp-route-id="@p.Id">
                                                Supprimer
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

    </div>
</div>