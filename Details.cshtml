@model BoutiqueEnLigne.Models.Product
@{
    ViewData["Title"] = Model.Title;
}

<div class="sj-page py-4">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <a class="btn sj-btn sj-btn-outline-gold"
               asp-controller="Product" asp-action="Index">
                ← Retour
            </a>
            <span class="sj-badge">@Model.Category</span>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="sj-card sj-card-hover overflow-hidden">
                    <div style="height:440px;background:rgba(0,0,0,.25);">
                        <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab" : Model.ImageUrl)"
                             style="width:100%;height:100%;object-fit:cover;display:block;" />
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="sj-hero">
                    <h1 class="sj-title mt-2">@Model.Title</h1>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <span class="sj-badge">Paiement sécurisé</span>
                        <span class="sj-badge">Livraison rapide</span>
                        <span class="sj-badge">Qualité</span>
                    </div>

                    <div class="mt-4">
                        <div class="sj-muted">Prix</div>
                        <div style="color: var(--sj-gold); font-weight:900; font-size:2rem;">
                            @Model.Price.ToString("0.00") $
                        </div>
                    </div>

                    <hr style="border-color: rgba(255,255,255,.12);" />

                    <div class="sj-text fw-bold mb-2">Description</div>
                    <p class="sj-muted" style="line-height:1.7;">
                        @Model.Description
                    </p>

                    <form method="post" asp-controller="Cart" asp-action="Add" class="mt-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button class="btn btn-warning btn-lg fw-bold rounded-3">Ajouter au panier</button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>