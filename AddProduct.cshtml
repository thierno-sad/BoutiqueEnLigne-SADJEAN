@model BoutiqueEnLigne.Models.Product
@{
    ViewData["Title"] = "Ajouter un produit";
}

<div class="sj-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="sj-hero mb-3">
                   
                    <h1 class="sj-title mt-2">Ajouter un produit</h1>
                    <p class="sj-subtitle mt-1">Publie un nouvel article dans ton espace vendeur.</p>
                </div>

                <div class="sj-card p-4 p-md-5">

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger rounded-3">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <form asp-action="AddProduct" method="post">
                        <div class="mb-3">
                            <label class="form-label sj-text fw-semibold">Titre</label>
                            <input asp-for="Title" class="form-control sj-input" placeholder="Ex: Hoodie SADJEAN" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label sj-text fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control sj-input" rows="4"
                                      placeholder="Décris ton produit..."></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label sj-text fw-semibold">Prix</label>
                                <input asp-for="Price" type="number" step="0.01" min="0" class="form-control sj-input" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label sj-text fw-semibold">Catégorie</label>
                                <input asp-for="Category" class="form-control sj-input" placeholder="Ex: vêtements" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label sj-text fw-semibold">Image URL</label>
                            <input asp-for="ImageUrl" class="form-control sj-input" placeholder="https://..." />
                            <div class="sj-muted small mt-1">Si vide, une image par défaut sera affichée.</div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button class="btn sj-btn sj-btn-gold btn-lg">Publier</button>
                            <a class="btn sj-btn sj-btn-outline-gold"
                               asp-controller="Seller" asp-action="Dashboard">
                                Retour Dashboard
                            </a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}